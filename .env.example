# Receipt Generator Admin Access
# Email address allowed to access the admin receipt generator
# Defaults to Susan's email if not set
ADMIN_EMAIL=morrowsus@gmail.com

# Email Service (Resend preferred)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM=noreply@yourdomain.com

# Alternative: SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Other email settings
RECEIVING_EMAIL=morrowsus@gmail.com

# For production deployments
VERCEL_URL=your-domain.com
NEXTAUTH_URL=https://your-domain.com